{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*", "netlify/functions/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    /* Build settings */
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": false,
    "outDir": "./dist",

    /* Language + Module resolution */
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Frontend (React/Vite) */
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable"],

    /* Base paths + aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    },

    /* Types */
    "types": ["node", "vite/client"]
  }
}
